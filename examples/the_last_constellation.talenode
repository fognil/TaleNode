      "087fa45b-46ff-4353-8da7-9207513c3b11": {
        "id": "087fa45b-46ff-4353-8da7-9207513c3b11",
        "node_type": {
          "Dialogue": {
            "speaker_id": "b2526a8f-6b60-43e5-b1a8-5691e855be52",
            "speaker_name": "Commander Voss",
            "text": "Agent. I'm Commander Voss. This station is a powder keg and you're the only diplomat the Council could spare. No pressure.",
            "emotion": "neutral",
            "portrait_override": "portraits/voss_serious.png",
            "audio_clip": null,
            "metadata": {}
          }
        },
        "position": [
