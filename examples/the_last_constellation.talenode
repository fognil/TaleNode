          }
        ],
        "outputs": [
          {
            "id": "849eb685-6ad6-422c-9c2b-c523d6b0e44b",
            "direction": "Output",
            "label": ""
          }
        ]
      },
      "0a6ef75e-7580-4acc-a780-34848b58586d": {
        "id": "0a6ef75e-7580-4acc-a780-34848b58586d",
        "node_type": {
          "Dialogue": {
            "speaker_id": "b2526a8f-6b60-43e5-b1a8-5691e855be52",
            "speaker_name": "Commander Voss",
            "text": "Against all odds... they signed. Both factions agreed to the Meridian Accord. The Veil Nebula will know peace.",
            "emotion": "happy",
            "portrait_override": null,
            "audio_clip": null,
            "metadata": {}
          }
        },
