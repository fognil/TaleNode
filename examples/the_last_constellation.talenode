    "barks": {
      "32c25667-f3c0-4ea9-bf69-d94433cb766d": [
        {
          "id": "d55dc0c4-1bcf-4dca-9ecd-eca20b75f650",
          "text": "Did you hear about the signal? Creepy stuff...",
          "condition_variable": null,
          "condition_value": null,
          "weight": 1.0
        },
        {
          "id": "c939fdbb-2ee8-4941-8a27-b1311300f8c2",
          "text": "Another diplomat? This station's getting crowded.",
          "condition_variable": null,
          "condition_value": null,
          "weight": 0.8
        }
      ],
      "4bb65652-aecd-404e-b9f7-cca82add68e3": [
        {
          "id": "f79c4323-2baa-440e-8658-89d113b364eb",
          "text": "Reminder: Station curfew begins at 2200 hours.",
          "condition_variable": null,
          "condition_value": null,
          "weight": 1.0
        },
        {
          "id": "092cf2f6-0798-4c18-9ee2-eb0121b8e696",
          "text": "Security alert levels remain elevated.",
          "condition_variable": "chapter",
          "condition_value": {
            "Int": 2
          },
          "weight": 1.0
        }
      ],
      "b2526a8f-6b60-43e5-b1a8-5691e855be52": [
        {
          "id": "7281c8d0-6383-4944-99ef-8d48fc7b08ef",
          "text": "The station's on edge. Keep your head down.",
          "condition_variable": "chapter",
          "condition_value": {
            "Int": 1
          },
          "weight": 1.0
        },
        {
          "id": "ea319466-8f30-47a9-bf98-e6d434499001",
          "text": "Progress. Good. Don't let up now.",
          "condition_variable": "peace_progress",
          "condition_value": {
            "Int": 2
          },
          "weight": 1.0
        },
        {
          "id": "5f28678e-4aa4-44dc-9e0e-a719619d1013",
          "text": "If this goes south, I'm holding you responsible.",
          "condition_variable": null,
          "condition_value": null,
          "weight": 0.5
        }
      ]
    },
    "quests": [
      {
        "id": "253f8e22-30a9-432c-9a0d-3b26a4537145",
        "name": "Diplomatic Mission",
        "description": "Negotiate peace between the Solari Dominion and Umbral Collective at Station Meridian.",
        "objectives": [
          {
            "id": "361fb33e-7093-43c5-b904-5745bd44caf9",
            "text": "Meet the faction leaders",
            "completed": false,
            "optional": false
          },
          {
            "id": "f89c5fc1-1385-4846-a2b6-092c5040ef7c",
            "text": "Gather evidence of the conspiracy",
            "completed": false,
            "optional": false
          },
          {
            "id": "d89003c5-e24c-4b6a-89a8-82f5deec40e9",
            "text": "Propose a resolution to both factions",
            "completed": false,
            "optional": false
          }
        ],
        "status": "InProgress"
      },
      {
        "id": "c4a9c748-fd09-463e-bc0a-3aa70410c205",
        "name": "Shadows on Meridian",
        "description": "Strange signals and sabotage threaten the station. Investigate the source.",
        "objectives": [
          {
            "id": "805332a5-8826-408b-b704-0920a3d29090",
            "text": "Investigate the anomalous signal in Dr. Chen's lab",
            "completed": false,
            "optional": false
          },
          {
            "id": "952ae18e-c479-440f-b77e-5141ed8bafa3",
            "text": "Find evidence of sabotage",
            "completed": false,
            "optional": false
          },
          {
            "id": "d825d083-7ed0-4d90-906c-1b4380a224c2",
            "text": "Confront or report the saboteur",
            "completed": false,
            "optional": false
          }
        ],
        "status": "NotStarted"
      },
      {
        "id": "837128a3-092c-4efb-952e-d324c97b25a8",
        "name": "The Smuggler's Deal",
        "description": "Zeph needs a favor. A simple delivery job... or is it?",
        "objectives": [
          {
            "id": "f66cb4c5-d2ea-458e-b6a7-e8a8c9dac272",
            "text": "Deliver Zeph's package to the contact",
            "completed": false,
            "optional": false
          },
          {
            "id": "c12a18ae-e203-4c17-86d3-d931fb874a59",
            "text": "Open the package to see what's inside",
            "completed": false,
            "optional": true
          }
        ],
        "status": "NotStarted"
      }
    ],
