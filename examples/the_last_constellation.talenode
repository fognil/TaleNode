      "f6673685-2ccd-4aa6-98fa-36a2342ec616": {
        "id": "f6673685-2ccd-4aa6-98fa-36a2342ec616",
        "node_type": {
          "Dialogue": {
            "speaker_id": "4e9448cf-ec0a-42e3-862b-404e98d7cab9",
            "speaker_name": "Dr. Elara Chen",
            "text": "I haven't told anyone this, but... the signal is artificial. And it's coming from inside the station. Someone on Meridian is broadcasting. The peace talks may be a cover.",
            "emotion": "scared",
            "portrait_override": null,
            "audio_clip": "audio/elara_whisper.wav",
            "metadata": {}
          }
        },
        "position": [
