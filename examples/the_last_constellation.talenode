      "f53fd8bb-85d4-489f-a568-35e7e730f7a3": {
        "id": "f53fd8bb-85d4-489f-a568-35e7e730f7a3",
        "node_type": {
          "Dialogue": {
            "speaker_id": "4bb65652-aecd-404e-b9f7-cca82add68e3",
            "speaker_name": "ARIA",
            "text": "Commander Voss has requested your presence in the command center. However, you are free to explore the station first. Tensions between the Solari and Umbral delegations are... elevated.",
            "emotion": "neutral",
