    "comments": [
      {
        "id": "708160f3-0828-45d3-b451-41963d29debf",
        "node_id": "39768070-74ad-4bd5-83d3-d42b33f9e3e5",
        "author": "",
        "text": "Verify that peace is achievable with typical playthroughs."
      },
      {
        "id": "5e79f9d6-cc81-4429-b116-227b34a1b31e",
        "node_id": "4d59ce13-f26f-4c33-a148-0245ad2c52de",
        "author": "",
        "text": "Consider adding a 'check inventory' option."
      },
      {
        "id": "22a7ffe5-a07c-48bf-b30c-66d75d7342ba",
        "node_id": "4f42811c-c5c0-4534-9292-b200702aefd7",
        "author": "",
        "text": "Balance faction paths — Thrix feels shorter than Kael."
      },
      {
        "id": "620bc28e-9b67-4ab1-b003-3f74571dce9e",
        "node_id": "b51d4881-19b7-4129-808e-732d7455744d",
        "author": "",
        "text": "Great opening — sets the sci-fi tone immediately."
      },
      {
        "id": "c1e12ff4-e772-4535-8664-322bd46db954",
        "node_id": "dad69c81-a687-4758-b034-623016749d70",
        "author": "",
        "text": "Playtest this ending — is it satisfying?"
      },
      {
        "id": "33d9503e-fe80-4351-8fd6-bf3d1b01db7b",
        "node_id": "f6673685-2ccd-4aa6-98fa-36a2342ec616",
        "author": "",
        "text": "This is the emotional core. Polish carefully."
      }
    ],
