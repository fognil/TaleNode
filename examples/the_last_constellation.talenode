      "09c4cb40-d737-461f-a4df-b9f89d55e408": {
        "id": "09c4cb40-d737-461f-a4df-b9f89d55e408",
        "node_type": {
          "Dialogue": {
            "speaker_id": "4bb65652-aecd-404e-b9f7-cca82add68e3",
            "speaker_name": "ARIA",
            "text": "Briefing summary: Station Meridian hosts 3,000 residents. The Solari delegation arrived 72 hours ago. The Umbral contingent arrived 48 hours ago. Three altercations have already been reported.",
            "emotion": "neutral",
            "portrait_override": null,
            "audio_clip": null,
            "metadata": {}
          }
        },
        "position": [
          1700.0,
