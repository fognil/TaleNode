        "f35d108e-9b66-46fd-abcf-3a5e9c8b7c5b": {
          "id": "f35d108e-9b66-46fd-abcf-3a5e9c8b7c5b",
          "node_type": {
            "SubGraph": {
              "name": "Zeph's Favor",
              "child_graph": {
                "nodes": {
                  "398fbe28-dbee-42d5-9325-4cff5c2c6937": {
                    "id": "398fbe28-dbee-42d5-9325-4cff5c2c6937",
                    "node_type": {
                      "Dialogue": {
                        "speaker_id": "32c25667-f3c0-4ea9-bf69-d94433cb766d",
                        "speaker_name": "Zeph",
                        "text": "Simple job: deliver this package to bay 7. Don't open it. Don't ask what's inside. Don't... okay, it's definitely not explosives.",
                        "emotion": "happy",
                        "portrait_override": null,
                        "audio_clip": null,
