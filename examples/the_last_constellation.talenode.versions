        "ddace9c4-5056-45ac-99ab-d158819a1daa": {
          "id": "ddace9c4-5056-45ac-99ab-d158819a1daa",
          "node_type": {
            "Dialogue": {
              "speaker_id": "b2526a8f-6b60-43e5-b1a8-5691e855be52",
              "speaker_name": "Commander Voss",
              "text": "The Solari Dominion wants expansion rights. The Umbral Collective demands isolation. Find common ground before they tear this station apart.",
