          "node_type": {
            "Dialogue": {
              "speaker_id": "4e9448cf-ec0a-42e3-862b-404e98d7cab9",
              "speaker_name": "Dr. Elara Chen",
              "text": "Oh! You must be the new envoy. I'm Dr. Elara Chen, chief science officer. Forgive the mess — I've been analyzing something extraordinary.",
