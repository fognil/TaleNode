            }
          ],
          "outputs": [
            {
              "id": "d66148c4-462e-4e28-bf69-6a9347698f89",
              "direction": "Output",
              "label": ""
            }
          ]
        },
        "cf6e38d8-7212-4964-b360-cc018e32de01": {
          "id": "cf6e38d8-7212-4964-b360-cc018e32de01",
          "node_type": {
            "Dialogue": {
              "speaker_id": "7b4bbb29-f627-4592-8564-ddb666502e56",
              "speaker_name": "Warden Thrix",
              "text": "The Umbral Collective does NOT need your interference! We survived centuries in the void alone. We do not bend.",
              "emotion": "angry",
              "portrait_override": null,
              "audio_clip": null,
              "metadata": {}
            }
          },
